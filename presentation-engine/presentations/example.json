      "content": [
        {
          "type": "text",
          "content": "Стрелочные функции — краткий синтаксис и сохранение контекста this."
        },
        {
          "type": "code",
          "language": "javascript",
          "code": "const add = (a, b) => a + b;\nconst double = x => x * 2;\n\n// Блок тела\nconst greet = (name) => {\n  return `Hello, ${name}!`;\n};"
